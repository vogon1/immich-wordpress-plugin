#. Plugin Name of the plugin
#: gallery-for-immich.php gallery-for-immich.php:237 gallery-for-immich.php:238
#: gallery-for-immich.php:408 build/index.js:1 src/index.js:263
msgid "Gallery for Immich"
msgstr "Galerij voor Immich"

#. Plugin URI of the plugin
#: gallery-for-immich.php
msgid "https://github.com/vogon1/immich-wordpress-plugin"
msgstr "https://github.com/vogon1/immich-wordpress-plugin"

#. Description of the plugin
#: gallery-for-immich.php
msgid ""
"Show Immich albums and photos in a WordPress site. Requires Immich server "
"with API access."
msgstr ""
"Toon Immich albums en foto's in een WordPress site met behulp van "
"shortcodes. Vereist Immich server met API toegang."

#. Author of the plugin
#: gallery-for-immich.php
msgid "Sietse Visser"
msgstr "Sietse Visser"

#. Author URI of the plugin
#: gallery-for-immich.php
msgid "https://github.com/vogon1"
msgstr "https://github.com/vogon1"

#: gallery-for-immich.php:20 gallery-for-immich.php:63
msgid ""
"Show Immich albums and photos in a WordPress site using shortcodes. Requires "
"Immich server with API access."
msgstr ""
"Toon Immich albums en foto's in een WordPress site met behulp van "
"shortcodes. Vereist Immich server met API toegang."

#: gallery-for-immich.php:250
msgid "Settings"
msgstr "Instellingen"

#: gallery-for-immich.php:252
msgid "Immich server URL"
msgstr "Immich server URL"

#: gallery-for-immich.php:253
msgid "API Key"
msgstr "API-sleutel"

#: gallery-for-immich.php:254
msgid "Video playback"
msgstr "Video afspelen"

#: gallery-for-immich.php:269
msgid "Server URL must start with http:// or https://."
msgstr "Server URL moet beginnen met http:// of https://."

#: gallery-for-immich.php:284
msgid "API Key contains invalid characters."
msgstr "API-sleutel bevat ongeldige tekens."

#: gallery-for-immich.php:311
msgid "Unencrypted connection"
msgstr "Onversleutelde verbinding"

#: gallery-for-immich.php:313
msgid "You are using an unencrypted HTTP connection."
msgstr "U gebruikt een onversleutelde HTTP-verbinding."

#: gallery-for-immich.php:314
msgid ""
"Your API key and photo data will be transmitted without encryption. This is "
"not recommended unless you are on a private local network."
msgstr ""
"Uw API-sleutel en fotogegevens worden verzonden zonder versleuteling. Dit "
"wordt afgeraden tenzij u zich op een privé lokaal netwerk bevindt."

#: gallery-for-immich.php:316
msgid "Cancel"
msgstr "Annuleren"

#: gallery-for-immich.php:317
msgid "Continue with HTTP"
msgstr "Doorgaan met HTTP"

#: gallery-for-immich.php:387
msgid "Shared links (default)"
msgstr "Shared links (standaard)"

#: gallery-for-immich.php:388
msgid "Proxy via fopen"
msgstr "Proxy via fopen"

#: gallery-for-immich.php:389
msgid "Ignore videos"
msgstr "Video's negeren"

#: gallery-for-immich.php:392
msgid "How it works:"
msgstr "Hoe het werkt:"

#: gallery-for-immich.php:393
msgid ""
"Proxy via fopen: Streams videos through this WordPress site. Most elegant, "
"but not all WordPress configurations support fopen. If it does not work for "
"you, choose Shared Links."
msgstr ""
"Proxy via fopen: streamt video's via deze WordPress site. Meest elegant, "
"maar niet alle WordPress-configuraties ondersteunen fopen. Als het niet voor "
"u werkt, kies Shared Links."

#: gallery-for-immich.php:394
msgid ""
"Shared links: Creates temporary shared links on Immich (bypasses WordPress "
"server). The temporary links expire after a short period and will be removed "
"from Immich."
msgstr ""
"Shared links: creëert tijdelijke gedeelde links op Immich (omzeilt WordPress-"
"server). De tijdelijke links verlopen na korte tijd en worden uit Immich "
"verwijderd."

#: gallery-for-immich.php:395
msgid "Ignore videos: Videos will not be displayed in galleries."
msgstr "Video's negeren: video's worden niet weergegeven in galerijen."

#: gallery-for-immich.php:403
msgid "You do not have sufficient permissions to access this page."
msgstr "Je hebt onvoldoende rechten om deze pagina te bekijken."

#: gallery-for-immich.php:418 gallery-for-immich.php:420
#: gallery-for-immich.php:430
msgid "Test connection & permissions"
msgstr "Verbinding & rechten testen"

#: gallery-for-immich.php:419
msgid ""
"After saving your settings, click the button below to verify that your API "
"key works and has all required permissions."
msgstr ""
"Sla uw instellingen op en klik op de knop hieronder om te controleren of uw "
"API-sleutel werkt en alle vereiste rechten heeft."

#: gallery-for-immich.php:431
msgid "Testing…"
msgstr "Bezig met testen…"

