#, php-format
msgid "Connection failed: %s"
msgstr "Verbinding mislukt: %s"

#: gallery-for-immich.php:1126
msgid "Plugin not configured. Please set Server URL and API Key in settings."
msgstr ""
"Plugin niet geconfigureerd. Stel Server URL en API-sleutel in bij "
