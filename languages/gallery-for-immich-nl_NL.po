msgid "Asset not found."
msgstr "Foto niet gevonden."

#: gallery-for-immich.php:1395
msgid "Video is not displayed."
msgstr "Video wordt niet weergegeven."

#: gallery-for-immich.php:1446 gallery-for-immich.php:1580
msgid ""
"Gallery preview not available in editor. This will display on the published "
