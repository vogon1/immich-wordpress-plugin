#. Plugin Name of the plugin
#: gallery-for-immich.php gallery-for-immich.php:245 gallery-for-immich.php:246
#: gallery-for-immich.php:416 build/index.js:1 src/index.js:300
msgid "Gallery for Immich"
msgstr "Galerie pour Immich"

#. Plugin URI of the plugin
#: gallery-for-immich.php
msgid "https://github.com/vogon1/immich-wordpress-plugin"
msgstr "https://github.com/vogon1/immich-wordpress-plugin"

#. Description of the plugin
#: gallery-for-immich.php
msgid ""
"Show Immich albums and photos in a WordPress site. Requires Immich server "
"with API access."
msgstr ""
"Affichez les albums et photos Immich sur un site WordPress à l'aide de "
"shortcodes. Nécessite un serveur Immich avec accès API."

#. Author of the plugin
#: gallery-for-immich.php
msgid "Sietse Visser"
msgstr "Sietse Visser"

#. Author URI of the plugin
#: gallery-for-immich.php
msgid "https://github.com/vogon1"
msgstr "https://github.com/vogon1"

#: gallery-for-immich.php:20 gallery-for-immich.php:63
msgid ""
"Show Immich albums and photos in a WordPress site using shortcodes. Requires "
"Immich server with API access."
msgstr ""
"Affichez les albums et photos Immich sur un site WordPress à l'aide de "
"shortcodes. Nécessite un serveur Immich avec accès API."

#: gallery-for-immich.php:258
msgid "Settings"
msgstr "Paramètres"

#: gallery-for-immich.php:260
msgid "Immich server URL"
msgstr "URL du serveur Immich"

#: gallery-for-immich.php:261
msgid "API Key"
msgstr "Clé API"

#: gallery-for-immich.php:262
msgid "Video playback"
msgstr "Lecture vidéo"

#: gallery-for-immich.php:277
msgid "Server URL must start with http:// or https://."
msgstr "L'URL du serveur doit commencer par http:// ou https://."

#: gallery-for-immich.php:292
msgid "API Key contains invalid characters."
msgstr "La clé API contient des caractères non valides."

#: gallery-for-immich.php:319
msgid "Unencrypted connection"
msgstr "Connexion non chiffrée"

#: gallery-for-immich.php:321
msgid "You are using an unencrypted HTTP connection."
msgstr "Vous utilisez une connexion HTTP non chiffrée."

#: gallery-for-immich.php:322
msgid ""
"Your API key and photo data will be transmitted without encryption. This is "
"not recommended unless you are on a private local network."
msgstr ""
"Votre clé API et vos données photos seront transmises sans chiffrement. Cela "
"n'est pas recommandé sauf si vous êtes sur un réseau local privé."

#: gallery-for-immich.php:324
msgid "Cancel"
msgstr "Annuler"

#: gallery-for-immich.php:325
msgid "Continue with HTTP"
msgstr "Continuer avec HTTP"

#: gallery-for-immich.php:395
msgid "Shared links (default)"
msgstr "Liens partagés (par défaut)"

#: gallery-for-immich.php:396
msgid "Proxy via fopen"
msgstr "Proxy via fopen"

#: gallery-for-immich.php:397
msgid "Ignore videos"
msgstr "Ignorer les vidéos"

#: gallery-for-immich.php:400
msgid "How it works:"
msgstr "Comment ça marche :"

#: gallery-for-immich.php:401
msgid ""
"Proxy via fopen: Streams videos through this WordPress site. Most elegant, "
"but not all WordPress configurations support fopen. If it does not work for "
"you, choose Shared Links."
msgstr ""
"Proxy via fopen : diffuse les vidéos via ce site WordPress. Le plus élégant, "
"mais toutes les configurations WordPress ne supportent pas fopen. Si cela ne "
"fonctionne pas pour vous, choisissez Liens partagés."

#: gallery-for-immich.php:402
msgid ""
"Shared links: Creates temporary shared links on Immich (bypasses WordPress "
"server). The temporary links expire after a short period and will be removed "
"from Immich."
msgstr ""
"Liens partagés : crée des liens partagés temporaires sur Immich (contourne "
"le serveur WordPress). Les liens temporaires expirent après une courte "
"période et seront supprimés d'Immich."

#: gallery-for-immich.php:403
msgid "Ignore videos: Videos will not be displayed in galleries."
msgstr ""
"Ignorer les vidéos : les vidéos ne seront pas affichées dans les galeries."

#: gallery-for-immich.php:411
msgid "You do not have sufficient permissions to access this page."
msgstr ""
"Vous n'avez pas les autorisations suffisantes pour accéder à cette page."

#: gallery-for-immich.php:426 gallery-for-immich.php:428
#: gallery-for-immich.php:438
msgid "Test connection & permissions"
msgstr "Tester la connexion & les permissions"

#: gallery-for-immich.php:427
msgid ""
"After saving your settings, click the button below to verify that your API "
"key works and has all required permissions."
msgstr ""
"Après avoir enregistré vos paramètres, cliquez sur le bouton ci-dessous pour "
"vérifier que votre clé API fonctionne et dispose de toutes les permissions "
"requises."

