#, php-format
msgid "Connection failed: %s"
msgstr "Verbindung fehlgeschlagen: %s"

#: gallery-for-immich.php:1158 gallery-for-immich.php:1193
msgid "Plugin not configured. Please set Server URL and API Key in settings."
msgstr ""
"Plugin nicht konfiguriert. Bitte legen Sie Server-URL und API-Schlüssel in "
"den Einstellungen fest."

#. translators: %d: HTTP status code number
#: gallery-for-immich.php:1179 gallery-for-immich.php:1216
#, php-format
msgid "API returned status code: %d"
msgstr "API hat Statuscode zurückgegeben: %d"

